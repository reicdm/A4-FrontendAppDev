                        <p class="text-center certsoft-title m-2">SOFTWARE</p>
                        <div class="row row-cols-4 g-1 mt-1 px-3 align-items-center justify-content-center text-center">
                            <div class="col"><img src="~/images/software/github.png" alt="GitHub" class="img-fluid" /></div>
                            <div class="col"><img src="~/images/software/mysql.png" alt="MySQL" class="img-fluid" /></div>
                            <div class="col"><img src="~/images/software/xampp.png" alt="Xampp" class="img-fluid" /></div>
                            <div class="col"><img src="~/images/software/vsc.png" alt="VSC" class="img-fluid" /></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <hr class="border border-5 opacity-100 hr-line mb-3 p-0">
        <div class="d-flex align-items-center">
            <img class="my-img mr-5" src="~/images/rei.png" alt="Rei's Photo" />

            <div class="vline"></div>

            <div class="d-flex flex-column align-self-start ml-5 work-links">
                <p class="work-title">WORK WITH ME!</p>
                <a href="https://mail.google.com/"><div class="d-flex align-items-center gap-4 mb-2"><img src="~/images/contact/email.png" alt="Email" /><span>rcdrmagpantay@gmail.com</span></div></a>
                <a href="https://www.linkedin.com/in/reina-chloe-magpantay/"><div class="d-flex align-items-center gap-4 mb-2"><img src="~/images/contact/linkedin.png" alt="LinkedIn" /><span>Reina Chloe Magpantay</span></div></a>
                <a href="https://github.com/reicdm"><div class="d-flex align-items-center gap-4 mb-2"><img src="~/images/contact/github.png" alt="GitHub" /><span>reicdm</span></div></a>
            </div>

            <div class="ms-auto">
                <img src="~/images/decor/decor1.png" alt="Photo" class="img-fluid decor-img" />
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-4">
        <hr class="border border-5 opacity-100 hr-line mb-3 mt-0 p-0">
        <p class="skills-title px-3">SKILLS</p>
        <div class="row mt-3 mx-0 p-3 border border-3 opacity-100 skills-row">
            <div class="col skills px-5">
                <div class="d-flex">
                    <div class="d-flex flex-column align-items-center me-3">
                        <img src="~/images/skills/html5.png" alt="HTML" class="mb-2" />
                        <img src="~/images/skills/css2.png" alt="CSS" class="mb-2" />
                        <img src="~/images/skills/mysql2.png" alt="SQL" class="mb-2" />
                        <img src="~/images/skills/php2.png" alt="LARAVEL" class="mb-2" />
                        <img src="~/images/skills/js2.png" alt="JAVASCRIPT" class="mb-2" />
                        <img src="~/images/skills/java2.png" alt="JAVA" class="mb-2" />
                        <img src="~/images/skills/python2.png" alt="PYTHON" class="mb-2" />
