@{
    ViewData["Title"] = "ABOUT ME";
}

<div class="row px-5">
    <div class="col-lg-8 col-md-8">
        <div class="row">
            <div class="col-lg-6 col-md-6">
                <div class="intro-box">
                    <p class="text-center mb-0 intro-txt">INTRODUCTION</p>
                    <p class="text-center text-break px-2 intro-txt2">
                        Hi, I'm Reina — a BS in Information Technology student at the Polytechnic University of the Philippines with a passion for web and app development. I love turning ideas into clean, functional digital experiences.
                    </p>
                </div>
                <div class="edu-box mt-2">
                    <p class="text-center edu-title">EDUCATION</p>
                    <p class="text-center edu-body">2023 - PRESENT</p>
                    <p class="text-center edu-body">Polytechnic University of the Philippines</p>
                    <p class="text-center edu-body">BS in Information Technology</p>
                </div>
            </div>
            <div class="col-lg-6 col-md-6">
                <div class="cert-soft p-3 border border-3 opacity-100">
