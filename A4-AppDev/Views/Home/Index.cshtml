                    <div class="border-start border-dark border-5 my-3"></div>
                    <div class="d-flex flex-column justify-content-around">
                        <p class="mb-2 fw-bold">HTML</p>
                        <p class="mb-2 fw-bold">CSS</p>
                        <p class="mb-2 fw-bold">SQL</p>
                        <p class="mb-2 fw-bold">LARAVEL (PHP)</p>
                        <p class="mb-2 fw-bold">JAVASCRIPT</p>
                        <p class="mb-2 fw-bold">JAVA</p>
                        <p class="mb-2 fw-bold">PYTHON</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>